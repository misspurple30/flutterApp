rules_version = '2';

// Règles de sécurité pour Flutter Chat App.
// À déployer avec : firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- USERS ----
    match /users/{uid} {
      // Tout utilisateur connecté peut lire les profils (pour liste & chat).
      allow read: if isSignedIn();
      // L'utilisateur ne peut créer/modifier que son propre document.
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    // ---- CHAT ROOMS ----
    match /chatRooms/{roomId} {
      // Seuls les participants peuvent voir la room.
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      // Création : l'auteur doit se trouver dans participants.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // Mise à jour : uniquement par les participants.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ---- MESSAGES ----
      match /messages/{messageId} {
        function roomParticipants() {
          return get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        }

        allow read: if isSignedIn()
          && request.auth.uid in roomParticipants();

        // Création : l'expéditeur est l'auteur authentifié et est dans la room.
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in roomParticipants();

        // Update : uniquement pour marquer isRead côté destinataire.
        allow update: if isSignedIn()
          && request.auth.uid in roomParticipants()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['isRead']);

        allow delete: if false;
      }
    }
  }
}
