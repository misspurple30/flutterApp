rules_version = '2';

// Règles pour Firebase Storage.
// À déployer avec : firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Photos de profil : l'utilisateur ne peut écrire que sur la sienne.
    match /profile_photos/{uid}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Images des chats : toute personne authentifiée peut lire/écrire dans
    // un dossier de room (les règles Firestore contrôlent déjà qui utilise
    // quelle room).
    match /chat_images/{roomId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
